rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ========= Helper Functions ========= */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'zorbyteofficial@gmail.com' ||
        request.auth.token.email == 'briston.miller@weatherfordisd.net'
      );
    }

    /* ========= Users ========= */

    match /users/{userId} {
      // Users can read their own profile
      allow read: if isSignedIn() && request.auth.uid == userId;

      // Users can update their profile (except tokens)
      allow update: if isSignedIn() && request.auth.uid == userId
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['tokens']));

      // Only admins can modify tokens directly (normal users get tokens via cloud functions)
      allow update: if isAdmin();

      // Platform admins can manage all users
      allow read, write, delete: if isAdmin();

      // User's games played subcollection
      match /gamesPlayed/{gameId} {
        // Users can manage their own game history
        allow read, write: if isSignedIn() && request.auth.uid == userId;

        // Admins can read all
        allow read: if isAdmin();
      }

      // User's lessons subcollection (existing math platform)
      match /lessons/{lessonId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
        allow read: if isAdmin();
      }

      // User's game saves subcollection (cross-device sync)
      match /gameSaves/{gameId} {
        // Users can manage their own game saves
        allow read, write: if isSignedIn() && request.auth.uid == userId;

        // Admins can read all
        allow read: if isAdmin();
      }

      // User's adaptive test states (in-progress tests)
      match /test-states/{subject} {
        // Users can manage their own test states
        allow read, write: if isSignedIn() && request.auth.uid == userId;

        // Admins can read all
        allow read: if isAdmin();
      }

      // User's completed adaptive tests
      match /adaptive-tests/{testId} {
        // Users can read and write their own test results
        allow read, write: if isSignedIn() && request.auth.uid == userId;

        // Admins can read all
        allow read: if isAdmin();
      }
    }

    /* ========= Schools ========= */

    match /schools/{schoolId} {

      // Any authenticated user can create a school
      allow create: if isSignedIn();

      // Read permissions
      allow read: if isSignedIn() && (
        resource.data.owner == request.auth.uid ||
        request.auth.uid in resource.data.members ||
        resource.data.visibility == 'public' ||
        isAdmin()
      );

      // Update permissions
      allow update: if isSignedIn() && (
        resource.data.owner == request.auth.uid ||
        request.auth.uid in resource.data.admins ||
        isAdmin()
      );

      // Delete permissions
      allow delete: if isSignedIn() && (
        resource.data.owner == request.auth.uid ||
        isAdmin()
      );
    }

    /* ========= Student Accounts ========= */

    match /studentAccounts/{studentId} {

      // School staff can create student accounts
      allow create: if isSignedIn();

      /*
        Public read is allowed for student login lookup.
        IMPORTANT: This means only non-sensitive fields should exist here.
      */
      allow read: if true;

      // Only creator or platform admin can modify
      allow update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.createdBy ||
        isAdmin()
      );
    }

    /* ========= Games ========= */

    match /games/{gameId} {
      // Anyone can read published games
      allow read: if resource == null || resource.data.published == true;

      // Admin can read all games (including unpublished)
      allow read: if isAdmin();

      // Anyone can increment play count and update lastPlayed (even non-authenticated users)
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['playCount', 'lastPlayed'])
        && request.resource.data.playCount == resource.data.playCount + 1;

      // Only admin can create or fully update/delete games
      allow create, delete: if isAdmin();
      allow update: if isAdmin();
    }

    /* ========= Game Metadata ========= */

    match /gameMetadata/{docId} {
      // Anyone can read metadata (categories, etc.)
      allow read: if true;

      // Only admin can modify metadata
      allow create, update, delete: if isAdmin();
    }

    /* ========= Announcements ========= */

    match /announcements/{announcementId} {
      // Anyone can read announcements (for public display)
      allow read: if true;

      // Only admin can create, update, or delete announcements
      allow create, update, delete: if isAdmin();
    }

    /* ========= Ome-Chat ========= */
    // Anonymous random video/text chat system
    // No authentication required - uses session-based IDs

    match /omechat/data {
      // Allow reading the data document itself
      allow read: if true;

      // Sessions - anonymous users manage their own sessions
      match /sessions/{sessionId} {
        // Anyone can create, read, update, delete sessions
        // (Session-based auth, not Firebase auth)
        allow create, read, update, delete: if true;
      }

      // Matching Queue - users waiting for matches
      match /matchingQueue/{sessionId} {
        allow create, read, update, delete: if true;
      }

      // Chat Rooms - active video/text chat sessions
      match /rooms/{roomId} {
        // Anyone can create and manage rooms
        allow create, read, update, delete: if true;

        // Messages subcollection for text chat
        match /messages/{messageId} {
          allow create, read: if true;
        }

        // ICE Candidates subcollection for WebRTC signaling
        match /candidates/{candidateId} {
          allow create, read: if true;
        }
      }

      // Moderation - ban and report tracking
      match /moderation/{sessionId} {
        // Allow creating and updating moderation records
        // (for bans and reports)
        allow create, read, update: if true;
      }
    }

    /* ========= G-Chat (Cloudflare Workers Edition) ========= */
    // Simplified rules - authentication handled by Cloudflare Workers
    // Session validation done client-side with Workers KV

    match /gchat {
      allow read: if true;

      // Profiles - public user profiles
      match /profiles/users/{userId} {
        allow read: if true; // Public profiles
        allow create, write: if true; // Users can create/update their own profiles
      }

      // Servers
      match /servers/list/{serverId} {
        allow read: if true; // Public server discovery
        allow create: if true; // Any authenticated user can create
        allow update, delete: if true; // Server ownership checked client-side

        // Channels
        match /channels/{channelId} {
          allow read: if true;
          allow create, update, delete: if true;

          // Messages
          match /messages/{messageId} {
            allow read: if true;
            allow create: if true; // Membership checked client-side
            allow delete: if true; // Ownership checked client-side
          }
        }
      }

      // Server Members (optional, not currently used)
      match /server-members/{serverId}/members/{userId} {
        allow read, write: if true;
      }

      // Featured Requests
      match /featured-requests/pending/{requestId} {
        allow read, create, update: if true;
        // Admin check done client-side
      }

      // Voice Sessions
      match /voice-sessions/active/{sessionId} {
        allow read, write: if true;

        // Signaling subcollection for WebRTC
        match /signaling/{signalId} {
          allow read, write: if true;
        }
      }
    }

    /* ========= Bug Reports ========= */
    // Anyone can create a report (no auth needed — same as Ome-Chat).
    // Only admins can read or update (e.g. mark resolved).

    match /bugReports/{reportId} {
      allow create: if true;
      allow read, update: if isAdmin();
    }

    /* ========= Staff Role Helpers ========= */

    // ---- Staff Collections ----

    match /staffRoles/{userId} {
      // Any staff member or hardcoded admin can read the full roles list
      allow read: if isAdmin() || (isSignedIn() &&
        exists(/databases/$(database)/documents/staffRoles/$(request.auth.uid)));

      // Only owners (hardcoded admins or role=owner) can grant/revoke roles
      allow create, update, delete: if isAdmin() || (isSignedIn() &&
        exists(/databases/$(database)/documents/staffRoles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/staffRoles/$(request.auth.uid)).data.role == 'owner');
    }

    /* ========= Courses (Draft) ========= */

    match /courses/{courseId} {
      // Published courses are publicly readable; drafts only by staff
      allow read: if resource == null ||
                     resource.data.status == 'published' ||
                     isAdmin() ||
                     (isSignedIn() && exists(/databases/$(database)/documents/staffRoles/$(request.auth.uid)));

      // Editors and above can create/update
      allow create, update: if isAdmin() ||
        (isSignedIn() &&
          exists(/databases/$(database)/documents/staffRoles/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/staffRoles/$(request.auth.uid)).data.role in ['owner', 'admin', 'editor']);

      // Only owners/hardcoded admins can delete
      allow delete: if isAdmin() ||
        (isSignedIn() &&
          exists(/databases/$(database)/documents/staffRoles/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/staffRoles/$(request.auth.uid)).data.role == 'owner');

      match /lessons/{lessonId} {
        allow read: if resource == null ||
                       get(/databases/$(database)/documents/courses/$(courseId)).data.status == 'published' ||
                       isAdmin() ||
                       (isSignedIn() && exists(/databases/$(database)/documents/staffRoles/$(request.auth.uid)));
        allow create, update: if isAdmin() ||
          (isSignedIn() &&
            exists(/databases/$(database)/documents/staffRoles/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/staffRoles/$(request.auth.uid)).data.role in ['owner', 'admin', 'editor']);
        allow delete: if isAdmin() ||
          (isSignedIn() &&
            exists(/databases/$(database)/documents/staffRoles/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/staffRoles/$(request.auth.uid)).data.role == 'owner');

        match /questions/{questionId} {
          allow read: if resource == null ||
                         get(/databases/$(database)/documents/courses/$(courseId)).data.status == 'published' ||
                         isAdmin() ||
                         (isSignedIn() && exists(/databases/$(database)/documents/staffRoles/$(request.auth.uid)));
          allow create, update: if isAdmin() ||
            (isSignedIn() &&
              exists(/databases/$(database)/documents/staffRoles/$(request.auth.uid)) &&
              get(/databases/$(database)/documents/staffRoles/$(request.auth.uid)).data.role in ['owner', 'admin', 'editor']);
          allow delete: if isAdmin() ||
            (isSignedIn() &&
              exists(/databases/$(database)/documents/staffRoles/$(request.auth.uid)) &&
              get(/databases/$(database)/documents/staffRoles/$(request.auth.uid)).data.role == 'owner');
        }
      }
    }

    /* ========= Published Courses (Student-facing snapshot) ========= */

    match /publishedCourses/{courseId} {
      // Fully public — students load course content without auth
      allow read: if true;

      // Only owners can write (publish action uses Cloud Function)
      allow create, update, delete: if isAdmin() ||
        (isSignedIn() &&
          exists(/databases/$(database)/documents/staffRoles/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/staffRoles/$(request.auth.uid)).data.role == 'owner');

      match /lessons/{lessonId} {
        allow read: if true;
        allow create, update, delete: if isAdmin() ||
          (isSignedIn() &&
            exists(/databases/$(database)/documents/staffRoles/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/staffRoles/$(request.auth.uid)).data.role == 'owner');

        match /questions/{questionId} {
          allow read: if true;
          allow create, update, delete: if isAdmin() ||
            (isSignedIn() &&
              exists(/databases/$(database)/documents/staffRoles/$(request.auth.uid)) &&
              get(/databases/$(database)/documents/staffRoles/$(request.auth.uid)).data.role == 'owner');
        }
      }
    }

    /* ========= Default Deny ========= */
    // Removed catch-all rule to prevent interference with specific permissions
    // Firestore denies by default if no rule matches
  }
}
